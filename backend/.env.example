# Copy to .env and fill in. On Railway, set these in the service's Variables tab.
GROQ_API_KEY=your_groq_api_key_here

# Railway provides this automatically when you add a PostgreSQL plugin.
# Leave unset locally to use SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256

# Comma-separated. In production, set this to your Vercel URL.
ALLOWED_ORIGINS=http://localhost:3000

# Only set to false locally if behind a VPN/proxy with SSL interception.
# Leave unset (defaults true) on Railway.
# GROQ_VERIFY_SSL=true

# Optional LangSmith observability
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=healthcare-triage
